# ── VWP Gateway — Environment Variables ──────────────────────────────────────
# Copy to .env and fill in real values before starting.

# Gateway port (default: 3200)
PORT=3200

# AAC server URL for publisher webhook URL resolution
AAC_SERVER_URL=http://localhost:3100

# Internal key for gateway → AAC server calls.
# Must match AIACTA_INTERNAL_KEY in the aac-server .env
AIACTA_INTERNAL_KEY=change-me-internal-gateway-key

# HMAC key used to sign outbound events forwarded to publisher webhooks.
# Publishers verify this with the ai-citation-sdk.
AIACTA_SIGNING_SECRET=change-me-generate-with-node-crypto-randombytes

# Provider HMAC keys — set one per enrolled provider (§3.4A)
# Provider signing keys — set at enrollment.
# If not set in production, the gateway refuses to start (fail-closed).
SIGNING_KEY_ANTHROPIC=
SIGNING_KEY_OPENAI=
SIGNING_KEY_GOOGLE=
