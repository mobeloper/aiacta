# ── AAC Reference Server — Environment Variables ─────────────────────────────
# Copy to .env and fill in real values before starting.
# Generate secret keys: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Server port (default: 3100)
PORT=3100

# Database
# SQLite database path. Use :memory: for tests.
AAC_DB_PATH=./aac.db

# API key protecting mutating endpoints (enrollment, distribution/commit).
# REQUIRED in production — server returns 503 on protected routes if not set.
AIACTA_API_KEY=change-me-generate-with-node-crypto-randombytes

# Internal key for gateway-to-server communication.
# Used by vwp-gateway to resolve publisher webhook URLs.
# Must match AIACTA_INTERNAL_KEY in the vwp-gateway .env
AIACTA_INTERNAL_KEY=change-me-internal-gateway-key

# API key for law enforcement / fact-checker provenance queries.
# Provenance API key — issued to authorised law enforcement / fact-checkers (§9.5.1)
# Required to access POST /v1/provenance/query and GET /v1/provenance/audit-trail/*
PROVENANCE_API_KEY=change-me-provenance-key
