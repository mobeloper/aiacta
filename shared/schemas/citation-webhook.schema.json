{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiacta.org/schemas/citation-webhook/v1.0",
  "title": "AIACTA Citation Webhook Event",
  "description": "Single-event and batch payload schema for POST citation webhooks (Proposal 2 §3.2)",
  "oneOf": [
    { "$ref": "#/definitions/SingleEvent" },
    { "$ref": "#/definitions/BatchPayload" }
  ],
  "definitions": {
    "SingleEvent": {
      "type": "object",
      "required": [
        "aiacta_version",
        "publisher",
        "base_url",
        "event_type",
        "event_id",
        "idempotency_key",
        "timestamp",
        "citation",
        "attribution"
      ],
      "properties": {
        "aiacta_version": { "type": "string", "enum": ["1.0"] },
        "publisher": { "type": "string" },
        "base_url": { "type": "string", "format": "uri" },
        "contact": { "type": "array", "items": { "type": "string" } },
        "event_type": { "type": "string", "enum": ["citation.generated"] },
        "event_id": { "type": "string" },
        "idempotency_key": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "citation": {
          "type": "object",
          "required": ["url", "citation_type"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "citation_type": {
              "type": "string",
              "enum": ["factual_source", "recommendation", "tool-result"]
            },
            "context_summary": { "type": "string", "maxLength": 500 },
            "query_category_l1": { "type": "string" },
            "query_category_l2": { "type": "string" },
            "model": { "type": "string" },
            "response_locale": { "type": "string" },
            "user_country": { "type": "string", "maxLength": 2 }
          }
        },
        "attribution": {
          "type": "object",
          "properties": {
            "display_type": {
              "type": "string",
              "enum": ["inline_link", "footnote", "none"]
            },
            "user_interface": {
              "type": "string",
              "enum": ["chat", "search", "api"]
            }
          }
        }
      }
    },
    "BatchPayload": {
      "type": "object",
      "required": ["batch_id", "aiacta_version", "events"],
      "properties": {
        "batch_id": { "type": "string" },
        "aiacta_version": { "type": "string", "enum": ["1.0"] },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/SingleEvent" },
          "maxItems": 100
        }
      }
    }
  }
}
