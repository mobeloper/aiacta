{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiacta.org/schemas/citation-webhook/v1.0",
  "title": "AIACTA Citation Webhook Event",
  "description": "Single event or batch payload for POST citation webhooks (Proposal 2 \u00a73.2)",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "event_type",
    "event_id",
    "idempotency_key",
    "timestamp",
    "citation",
    "attribution"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "provider": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "citation.generated"
      ]
    },
    "event_id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Minute precision only (\u00a73.2) \u2014 seconds always 00"
    },
    "citation": {
      "type": "object",
      "required": [
        "url",
        "citation_type"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "citation_type": {
          "type": "string",
          "enum": [
            "factual_source",
            "recommendation",
            "tool-result"
          ]
        },
        "context_summary": {
          "type": "string",
          "maxLength": 500
        },
        "query_category_l1": {
          "type": "string"
        },
        "query_category_l2": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "response_locale": {
          "type": "string"
        },
        "user_country": {
          "type": "string",
          "maxLength": 2,
          "description": "Country-level only \u2014 never finer (\u00a73.3)"
        }
      }
    },
    "attribution": {
      "type": "object",
      "properties": {
        "display_type": {
          "type": "string",
          "enum": [
            "inline_link",
            "footnote",
            "none"
          ]
        },
        "user_interface": {
          "type": "string",
          "enum": [
            "chat",
            "search",
            "api"
          ]
        }
      }
    },
    "batch_id": {
      "type": "string",
      "description": "Present only when this is a batch container (\u00a73.6)"
    },
    "events": {
      "type": "array",
      "description": "Present only in batch payloads (\u00a73.6)",
      "maxItems": 100
    }
  }
}